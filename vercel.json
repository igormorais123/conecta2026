{
  "rewrites": [
    { "source": "/conecta2026", "destination": "/index.html" },
    { "source": "/conecta2026/", "destination": "/index.html" },
    { "source": "/conecta2026/manifest.json", "destination": "/manifest.json" },
    { "source": "/conecta2026/favicon.ico", "destination": "/favicon.ico" },
    { "source": "/conecta2026/service-worker.js", "destination": "/service-worker.js" }
  ],
  "headers": [
    {
      "source": "/conecta2026/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
